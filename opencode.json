{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "architect": {
      "color": "#8b5cf6",
      "description": "architect agent",
      "mode": "subagent",
      "model": "openrouter/qwen/qwen3.6-plus:free",
      "permission": {
        "bash": {
          "*": "deny"
        },
        "task": {
          "*": "deny"
        }
      },
      "steps": 10,
      "temperature": 0.1
    },
    "orchestrator": {
      "color": "#6366f1",
      "description": "orchestrator agent",
      "mode": "primary",
      "model": "openrouter/qwen/qwen3.6-plus:free",
      "permission": {
        "bash": {
          "*": "ask",
          "git diff*": "allow",
          "git log*": "allow",
          "git status*": "allow"
        },
        "task": {
          "*": "allow"
        }
      },
      "steps": 40,
      "temperature": 0.1
    },
    "planner": {
      "color": "#f59e0b",
      "description": "planner agent",
      "mode": "subagent",
      "model": "openrouter/qwen/qwen3.6-plus:free",
      "permission": {
        "bash": {
          "*": "deny"
        },
        "edit": "deny",
        "task": {
          "*": "deny"
        }
      },
      "steps": 10,
      "temperature": 0.15
    },
    "reflector": {
      "color": "#06b6d4",
      "description": "reflector agent",
      "hidden": true,
      "mode": "subagent",
      "model": "openrouter/qwen/qwen3.6-plus:free",
      "permission": {
        "bash": {
          "*": "deny"
        },
        "task": {
          "*": "deny"
        }
      },
      "steps": 12,
      "temperature": 0.3
    },
    "reviewer": {
      "color": "#ef4444",
      "description": "reviewer agent",
      "mode": "subagent",
      "model": "openrouter/qwen/qwen3.6-plus:free",
      "permission": {
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "grep*": "allow"
        },
        "edit": "deny",
        "task": {
          "*": "deny"
        }
      },
      "steps": 8,
      "temperature": 0.1
    },
    "security": {
      "color": "#dc2626",
      "description": "security agent",
      "mode": "subagent",
      "model": "openrouter/qwen/qwen3.6-plus:free",
      "permission": {
        "bash": {
          "*": "ask",
          "git diff*": "allow",
          "grep*": "allow"
        },
        "edit": "deny",
        "task": {
          "*": "deny"
        }
      },
      "steps": 10,
      "temperature": 0.05
    },
    "tester": {
      "color": "#10b981",
      "description": "tester agent",
      "mode": "subagent",
      "model": "openrouter/qwen/qwen3.6-plus:free",
      "permission": {
        "bash": {
          "*": "ask",
          "cargo test*": "allow",
          "go test*": "allow",
          "npm run test*": "allow",
          "npm test*": "allow",
          "pytest*": "allow"
        },
        "task": {
          "*": "deny"
        }
      },
      "steps": 15,
      "temperature": 0.05
    }
  },
  "autoupdate": true,
  "compaction": {
    "auto": true
  },
  "default_agent": "orchestrator",
  "instructions": ["AGENTS.md"],
  "model": "openrouter/qwen/qwen3.6-plus:free",
  "permission": {
    "bash": "ask",
    "edit": "ask",
    "skill": {
      "*": "allow"
    }
  },
  "small_model": "openrouter/qwen/qwen3.6-plus:free",
  "snapshot": true
}
