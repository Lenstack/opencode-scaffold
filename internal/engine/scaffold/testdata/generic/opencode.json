{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "snapshot": true,
  "instructions": [
    "AGENTS.md"
  ],
  "permission": {
    "bash": "ask",
    "edit": "ask",
    "skill": {
      "*": "allow"
    }
  },
  "compaction": {
    "enabled": true
  },
  "agent": {
    "architect": {
      "mode": "subagent",
      "description": "architect agent",
      "steps": 10,
      "temperature": 0.1,
      "permission": {
        "bash": {
          "*": "deny"
        },
        "task": {
          "*": "deny"
        }
      },
      "color": "#8b5cf6"
    },
    "orchestrator": {
      "mode": "primary",
      "description": "orchestrator agent",
      "steps": 40,
      "temperature": 0.1,
      "permission": {
        "bash": {
          "*": "ask",
          "git diff*": "allow",
          "git log*": "allow",
          "git status*": "allow"
        },
        "task": {
          "*": "allow"
        }
      },
      "color": "#6366f1"
    },
    "planner": {
      "mode": "subagent",
      "description": "planner agent",
      "steps": 10,
      "temperature": 0.15,
      "permission": {
        "bash": {
          "*": "deny"
        },
        "edit": "deny",
        "task": {
          "*": "deny"
        }
      },
      "color": "#f59e0b"
    },
    "reflector": {
      "mode": "subagent",
      "description": "reflector agent",
      "steps": 12,
      "temperature": 0.3,
      "permission": {
        "bash": {
          "*": "deny"
        },
        "task": {
          "*": "deny"
        }
      },
      "hidden": true,
      "color": "#06b6d4"
    },
    "reviewer": {
      "mode": "subagent",
      "description": "reviewer agent",
      "steps": 8,
      "temperature": 0.1,
      "permission": {
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "grep*": "allow"
        },
        "edit": "deny",
        "task": {
          "*": "deny"
        }
      },
      "color": "#ef4444"
    },
    "security": {
      "mode": "subagent",
      "description": "security agent",
      "steps": 10,
      "temperature": 0.05,
      "permission": {
        "bash": {
          "*": "ask",
          "git diff*": "allow",
          "grep*": "allow"
        },
        "edit": "deny",
        "task": {
          "*": "deny"
        }
      },
      "color": "#dc2626"
    },
    "tester": {
      "mode": "subagent",
      "description": "tester agent",
      "steps": 15,
      "temperature": 0.05,
      "permission": {
        "bash": {
          "*": "ask",
          "cargo test*": "allow",
          "go test*": "allow",
          "npm run test*": "allow",
          "npm test*": "allow",
          "pytest*": "allow"
        },
        "task": {
          "*": "deny"
        }
      },
      "color": "#10b981"
    }
  },
  "default_agent": "orchestrator"
}
