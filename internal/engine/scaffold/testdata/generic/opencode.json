{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-20250514",
  "small_model": "anthropic/claude-haiku-4-20250514",
  "autoupdate": true,
  "snapshot": true,
  "instructions": [
    "AGENTS.md"
  ],
  "permission": {
    "bash": "ask",
    "edit": "ask",
    "skill": {
      "*": "allow"
    }
  },
  "compaction": {
    "enabled": true
  },
  "agent": {
    "architect": {
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-20250514",
      "description": "architect agent",
      "steps": 10,
      "temperature": 0.1,
      "permission": {
        "bash": {
          "*": "deny"
        }
      }
    },
    "orchestrator": {
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-20250514",
      "description": "orchestrator agent",
      "steps": 40,
      "temperature": 0.1,
      "permission": {
        "bash": {
          "*": "ask",
          "git diff*": "allow",
          "git log*": "allow",
          "git status*": "allow"
        }
      }
    },
    "planner": {
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-20250514",
      "description": "planner agent",
      "steps": 10,
      "temperature": 0.15,
      "permission": {
        "bash": {
          "*": "deny"
        },
        "edit": "deny"
      }
    },
    "reflector": {
      "mode": "subagent",
      "model": "anthropic/claude-haiku-4-20250514",
      "description": "reflector agent",
      "steps": 12,
      "temperature": 0.3,
      "permission": {
        "bash": {
          "*": "deny"
        }
      }
    },
    "reviewer": {
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-20250514",
      "description": "reviewer agent",
      "steps": 8,
      "temperature": 0.1,
      "permission": {
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "grep*": "allow"
        },
        "edit": "deny"
      }
    },
    "security": {
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-20250514",
      "description": "security agent",
      "steps": 10,
      "temperature": 0.05,
      "permission": {
        "bash": {
          "*": "ask",
          "git diff*": "allow",
          "grep*": "allow"
        },
        "edit": "deny"
      }
    },
    "tester": {
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-20250514",
      "description": "tester agent",
      "steps": 15,
      "temperature": 0.05,
      "permission": {
        "bash": {
          "*": "ask",
          "cargo test*": "allow",
          "go test*": "allow",
          "npm run test*": "allow",
          "npm test*": "allow",
          "pytest*": "allow"
        }
      }
    }
  },
  "default_agent": "orchestrator"
}
